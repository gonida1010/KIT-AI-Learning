# OpenAI (기본 프로바이더)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# LLM 프로바이더 전환: "openai" | "onpremise"
LLM_PROVIDER=openai

# On-Premise LLM (폐쇄망 전환 시)
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=your-model-name
# LLM_API_KEY=not-needed

# 임베딩 프로바이더: "openai" | "onpremise"
EMBEDDING_PROVIDER=openai
# EMBEDDING_BASE_URL=http://localhost:8000/v1
# EMBEDDING_MODEL=default

# 카카오 OAuth
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:3000/oauth/callback

# 프론트엔드
FRONTEND_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000

# 데이터 저장 경로 (배포 시 디스크 마운트 경로)
# DATA_DIR=/data

# PostgreSQL 데이터베이스 URL (필수)
DATABASE_URL=postgresql://user:password@localhost:5432/kit_ai_learning

# 시드 데이터 로드 여부: "1" = 로드 (개발), "0" = 빈 상태 시작 (프로덕션)
SEED_DATA=1
KAKAO_REDIRECT_URI=http://localhost:3000/oauth/callback

# 프론트엔드 URL (QR 로그인용)
FRONTEND_URL=http://localhost:3000

# CORS 허용 프론트엔드 주소
CORS_ALLOW_ORIGINS=http://localhost:3000
